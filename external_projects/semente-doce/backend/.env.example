APP_NAME="Semente Doce"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://semente-doce.meadadigital.local

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=semente-postgres
DB_PORT=5432
DB_DATABASE=semente_doce
DB_USERNAME=semente
DB_PASSWORD=semente_secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="oi@sementedoce.com.br"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Mercado Pago Checkout Transparente — credenciais em https://www.mercadopago.com.br/developers (use as de TESTE)
MP_ENABLED=false
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=
# Base pública p/ retorno e webhook (ngrok em dev); vazio = APP_URL
MP_BACK_URL_BASE=

# Login social Google — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# Entrega local (estilo iFood) — retirada na loja + entrega por bairro
DELIVERY_PICKUP_ENABLED=true
DELIVERY_MIN_ORDER=30
DELIVERY_FREE_ABOVE=150
DELIVERY_DEFAULT_FEE=12.90
DELIVERY_ORIGIN="Rua das Sementes, 100 — Centro"
# Tempo estimado de preparo/entrega mostrado na loja (minutos)
DELIVERY_ETA_MIN=40
DELIVERY_ETA_MAX=70
