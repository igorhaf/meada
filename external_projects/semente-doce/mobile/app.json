{
    "expo": {
        "name": "Semente Doce",
        "slug": "semente-doce",
        "version": "0.1.0",
        "scheme": "sementedoce",
        "orientation": "portrait",
        "userInterfaceStyle": "light",
        "newArchEnabled": true,
        "backgroundColor": "#fff8f1",
        "ios": {
            "supportsTablet": false,
            "bundleIdentifier": "com.meadadigital.sementedoce"
        },
        "android": {
            "package": "com.meadadigital.sementedoce",
            "edgeToEdgeEnabled": true
        },
        "plugins": ["expo-router"],
        "experiments": {
            "typedRoutes": true
        },
        "extra": {
            "apiUrl": "http://semente-doce.meadadigital.local/api/v1"
        }
    }
}
