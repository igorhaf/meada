APP_NAME=Pindorama
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://pindorama.meadadigital.local

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=pindorama-postgres
DB_PORT=5432
DB_DATABASE=pindorama
DB_USERNAME=pindorama
DB_PASSWORD=pindorama_secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="contato@pindorama.com.br"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Marketplace: mostra/oculta "Seja um terapeuta" e o painel do profissional (root sempre acessa)

# Agenda: fuso e antecedência mínima (min) para reservar horário no mesmo dia
PINDORAMA_TIMEZONE=America/Sao_Paulo
PINDORAMA_MIN_LEAD_MINUTES=60

# Mercado Pago Checkout Transparente — credenciais em https://www.mercadopago.com.br/developers (use as de TESTE)
MP_ENABLED=false
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=
MP_WEBHOOK_TOLERANCE=300
# Base pública p/ retorno e webhook (ngrok em dev); vazio = APP_URL
MP_BACK_URL_BASE=

# Login social Google — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"
